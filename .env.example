# PostgreSQL (runtime: app, seeds, migrate)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Só build da imagem Docker (prisma generate; não conecta ao banco). Opcional; o compose tem default.
# DATABASE_URL_BUILD=postgresql://placeholder:placeholder@127.0.0.1:5432/placeholder?schema=public

# MinIO S3-compatible API (not the web console URL unless it proxies S3)
MINIO_URL=https://your-minio-host:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET_DOCUMENTS=cvs

# Optional; defaults to us-east-1 (MinIO ignores it for most operations)
# MINIO_REGION=us-east-1

# Optional HTTPS base for building public object links (same host as MINIO_URL if exposed)
# MINIO_PUBLIC_URL=

# Google Sheets → CVs (export CSV: folha partilhada "Qualquer pessoa com o link pode ver")
# ID da folha: parte do URL entre /d/ e /edit (ex.: planilha TATICCA)
# GOOGLE_SHEETS_SPREADSHEET_ID=17LnL0rTinbXt6nH-Cat5A47QRL4z7vadXG5YFS-2jgI
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_GID=0
# Coluna do PDF (1=A, 4=D). Só precisa se os cabeçalhos forem ambíguos.
# GOOGLE_SHEETS_CV_URL_COLUMN_INDEX=4
# Opcional: URL completo do CSV (substitui SPREADSHEET_ID + GID)
# GOOGLE_SHEETS_CSV_URL=

# Proteção da rota GET /api/cron/sync-google-sheet (Bearer token)
CRON_SECRET=

# Google AI — extração estruturada de CV em PDF (Gemini). Usado no job de sync da planilha por cada PDF descarregado.
GEMINI_API_KEY=
# Opcional (ex.: gemini-2.0-flash, gemini-1.5-flash)
# GEMINI_MODEL=gemini-2.0-flash

# Docker scheduler (opcional)
# URL interna usada pelo container sync-scheduler para chamar o endpoint de cron.
# Exemplo padrão no docker-compose: http://app:3000/api/cron/sync-google-sheet
# SYNC_CRON_URL=http://app:3000/api/cron/sync-google-sheet
# 43200 segundos = 12 horas
# SYNC_CRON_INTERVAL_SECONDS=43200
