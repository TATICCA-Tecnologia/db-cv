DATABASE_URL="file:./prisma/dev.db"

# MinIO S3-compatible API (not the web console URL unless it proxies S3)
MINIO_URL=https://your-minio-host:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET_DOCUMENTS=cvs

# Optional; defaults to us-east-1 (MinIO ignores it for most operations)
# MINIO_REGION=us-east-1

# Optional HTTPS base for building public object links (same host as MINIO_URL if exposed)
# MINIO_PUBLIC_URL=
