DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
AUTH_SECRET="generate-with-openssl-rand-base64-32"


MINIO_URL=https://your-minio-host:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET_DOCUMENTS=cvs

# MINIO_REGION=us-east-1

# MINIO_PUBLIC_URL=

# Google Sheets → CVs (export CSV: folha partilhada "Qualquer pessoa com o link pode ver")
# ID da folha: parte do URL entre /d/ e /edit (ex.: planilha TATICCA)
# GOOGLE_SHEETS_SPREADSHEET_ID=17LnL0rTinbXt6nH-Cat5A47QRL4z7vadXG5YFS-2jgI
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_GID=0
# Para 2 abas específicas, prefira configurar os GIDs abaixo:
# GOOGLE_SHEETS_GID_PROFISSIONAIS_EXPERIENTES=
# GOOGLE_SHEETS_GID_ESTUDANTES_UNIVERSITARIOS=
# Alternativa genérica para múltiplas abas: lista separada por vírgula
# GOOGLE_SHEETS_GIDS=0,123456789
# Coluna do PDF (1=A, 8=H). Só precisa se os cabeçalhos forem ambíguos.
# GOOGLE_SHEETS_CV_URL_COLUMN_INDEX=8
# Opcional: URL completo do CSV (substitui SPREADSHEET_ID + GID)
# GOOGLE_SHEETS_CSV_URL=

CRON_SECRET=

GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# SYNC_CRON_URL=http://app:3000/api/cron/sync-google-sheet
# 43200 segundos = 12 horas
# SYNC_CRON_INTERVAL_SECONDS=43200
